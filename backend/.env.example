# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker Postgres (default for docker compose up)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prodeazo"

# Supabase Pooler Session mode (port 5432) — use for remote/staging
# DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── Auth secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="change_this_to_a_random_64_byte_hex_string"
JWT_SECRET="change_this_to_a_different_random_64_byte_hex_string"

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
# Local: http://localhost:4000/api/auth/callback
# Production (Vercel rewrite): https://prodeazo.vercel.app/api/auth/callback
# Production (direct to Render): https://prodeazo.onrender.com/api/auth/callback
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/callback"

FRONTEND_URL="http://localhost:3000"

# ── External APIs ──────────────────────────────────────────────────────────────
BZZOIRO_API_KEY="your_bzzoiro_api_key"
BZZOIRO_BASE_URL="https://sports.bzzoiro.com/api"
BSD_TIMEZONE=UTC

# ── Email (Forgot / Reset Password) ───────────────────────────────────────────
SMTP_USER="prodeazoapp@gmail.com"
SMTP_PASS="your_gmail_app_password"

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Disable TLS cert check for local Supabase/self-signed certs (never set in production)
# NODE_TLS_REJECT_UNAUTHORIZED=0
